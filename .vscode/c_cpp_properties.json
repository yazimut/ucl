{
    "env": {
        "projectDefines": [
            "UCL_EXPORTS",
            "UCL_${config:ucl.link_type}"
        ],
        "projectIncludes": [
            "${workspaceFolder}/include"
        ]
    },
    "configurations": [{
            "name": "Linux (debug)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "DEBUG"
            ],
            "compilerPath": "/usr/bin/g++",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"

        }, {
            "name": "Linux (release)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "NDEBUG"
            ],
            "compilerPath": "/usr/bin/g++",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"

        }, {
            "name": "Windows (debug)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "DEBUG"
            ],
            "compilerPath": "${env:MinGW}\\g++.exe",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64"

        }, {
            "name": "Windows (release)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "NDEBUG"
            ],
            "compilerPath": "${env:MinGW}\\g++.exe",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64"
        }],
    "version": 4
}
